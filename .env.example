# RAG System Environment Configuration
# Copy this file to .env and adjust values as needed

# ============ PROVIDER SETTINGS ============
# Options: ollama, vllm, openai
PROVIDER=ollama

# ============ OLLAMA SETTINGS ============
OLLAMA_BASE_URL=http://ollama:11434
CHAT_MODEL=mistral:7b
EMBEDDING_MODEL=nomic-embed-text

# ============ QDRANT SETTINGS ============
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=wp_ai_receptionist

# ============ DOCUMENT PROCESSING ============
UPLOAD_FOLDER=/tmp/uploads
MAX_FILE_SIZE=52428800  # 50MB in bytes
ALLOWED_ORIGINS=*

# ============ CHUNKING SETTINGS ============
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ============ EMBEDDING SETTINGS ============
EMBEDDING_BATCH_SIZE=32

# ============ RAG QUERY SETTINGS ============
SIMILARITY_THRESHOLD=0.7
MAX_CONTEXT_CHUNKS=5

# ============ LOGGING ============
LOG_LEVEL=INFO
FLASK_ENV=development

# ============ PORTS (if running without docker-compose) ============
# API_GATEWAY_PORT=3000
# DOC_PROCESSOR_PORT=4001
# RAG_SERVICE_PORT=4002
# CHUNK_SERVICE_PORT=4003
# EMBEDDING_SERVICE_PORT=4004
